{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "noEmit": true,
    "lib": ["DOM", "DOM.Iterable", "ES2018"]
  },
  "include": ["core/**/*.ts", "src/**/*.ts"]
}
