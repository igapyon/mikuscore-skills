{
  "name": "mikuscore",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "mikuscore": "scripts/mikuscore-cli.mjs"
  },
  "scripts": {
    "build": "npm run typecheck && npm run test:build && npm run build:dist",
    "build:all": "npm run build",
    "build:dist": "node scripts/build.mjs",
    "cli": "node scripts/mikuscore-cli.mjs",
    "check:all": "npm run typecheck && npm run test:all && npm run build:dist",
    "build:vendor:utaformatix3": "bash scripts/sync-utaformatix3-vendor.sh",
    "clean": "rm -rf mikuscore.html src/js/main.js .tsbuildinfo .mikuscore-build",
    "test:build": "vitest run tests/unit --exclude tests/unit/cffp-series.spec.ts --exclude tests/unit/mei-io.spec.ts --exclude tests/unit/musescore-io.spec.ts",
    "test:integration": "vitest run tests/unit/cffp-series.spec.ts tests/unit/mei-io.spec.ts tests/unit/musescore-io.spec.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/unit",
    "test:property": "vitest run tests/property",
    "test:all": "vitest run",
    "test:unit:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "5.9.3",
    "vitest": "^3.2.0",
    "jsdom": "^26.1.0"
  }
}
